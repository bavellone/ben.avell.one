---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Nothing here!" description="The page you're looking for doesn't exist.">
  <section class="container-page mt-24 sm:mt-32">
    <p class="text-[var(--text-meta)] uppercase tracking-widest text-[var(--color-ink-faint)]">404</p>
    <h1 class="mt-3 text-[var(--text-display)] font-semibold leading-[var(--leading-tight)] tracking-tight">
      Nothing here :/
    </h1>
    <p class="mt-6 max-w-prose text-[var(--text-lead)] text-[var(--color-ink-soft)]">
      There's nothing at this address. Perhaps a stale or mistyped link?
    </p>
    <p class="mt-8 flex flex-wrap gap-6">
      <a href="/">Home</a>
      <a href="/case-studies">Case Studies</a>
    </p>
  </section>
</BaseLayout>
