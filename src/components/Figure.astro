---
// A captioned figure. When it renders an image (`src`), the image is
// click-to-zoom: the frame becomes the trigger <a> that opens a full-screen
// :target lightbox, the same pure-CSS affordance the Projects page and the
// WPMH diagrams use (styles live in global.css under .zoomable/.lightbox).
// Slotted content (video, embeds) is never zoomable. Pass zoom={false} to
// opt a standalone image out.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src?: ImageMetadata;
  alt?: string;
  caption?: string;
  /**
   * Optional explicit width/sizing hint. Defaults to the natural image width
   * up to the content column.
   */
  widths?: number[];
  sizes?: string;
  /** Click-to-zoom lightbox for the image. Ignored for slotted content. */
  zoom?: boolean;
  /** Override the auto-generated lightbox id; must be unique on the page. */
  id?: string;
}

const { src, alt, caption, widths, sizes, zoom = true, id } = Astro.props;

// Zoom only makes sense for real images, never slotted video/embeds.
const zoomable = Boolean(src) && zoom;
const lightboxId = id ?? `fig-${crypto.randomUUID()}`;
const triggerId = `${lightboxId}-t`;
const lightboxWidths = src ? [768, 1280, src.width] : [768, 1280];

// The frame is an <a> when zoomable (so it can trigger the lightbox) and a
// <div> otherwise; both share the same visual chrome.
const Frame = zoomable ? "a" : "div";
const frameProps = zoomable
  ? { id: triggerId, href: `#${lightboxId}`, "aria-label": `Enlarge image: ${alt ?? ""}` }
  : {};
const frameClass =
  "overflow-hidden rounded-xl bg-[color-mix(in_oklab,var(--color-ink)_4%,transparent)]";
---

<figure class="my-8">
  <Frame class:list={["figure__media", frameClass, { zoomable }]} {...frameProps}>
    {
      src ? (
        <Image
          src={src}
          alt={alt ?? ""}
          widths={widths ?? [480, 768, 1024]}
          sizes={sizes ?? "(min-width: 768px) 700px, 100vw"}
          class="block h-auto w-full"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <slot />
      )
    }
    {
      zoomable && (
        <span class="zoomable__hint" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
            <line x1="11" y1="8" x2="11" y2="14" />
            <line x1="8" y1="11" x2="14" y2="11" />
          </svg>
        </span>
      )
    }
  </Frame>
  {
    zoomable && (
      <div id={lightboxId} class="lightbox" aria-label={`Enlarged: ${alt ?? ""}`}>
        <a href={`#${triggerId}`} class="lightbox__bg" aria-label="Close enlarged image" />
        <Image
          src={src!}
          alt={alt ?? ""}
          widths={lightboxWidths}
          sizes="(min-width: 1280px) 1280px, 100vw"
          class="lightbox__img"
        />
      </div>
    )
  }
  {
    caption && (
      <figcaption class="mt-3 text-[var(--text-meta)] text-[var(--color-ink-faint)]">
        {caption}
      </figcaption>
    )
  }
</figure>
