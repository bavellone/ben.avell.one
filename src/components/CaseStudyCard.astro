---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"caseStudies">;
}
const { entry } = Astro.props;
const { title, oneline, heroTreatment, heroImage, heroAlt } = entry.data;
const href = `/case-studies/${entry.id}`;
---

<article class="group">
  <a href={href} class="block no-underline">
    <div class="aspect-[3/2] w-full overflow-hidden rounded-lg bg-[color-mix(in_oklab,var(--color-ink)_4%,transparent)]">
      {
        heroTreatment === "image" && heroImage ? (
          heroImage.format === "svg" ? (
            <Image
              src={heroImage}
              alt={heroAlt ?? ""}
              class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
          ) : (
            <Image
              src={heroImage}
              alt={heroAlt ?? ""}
              widths={[400, 640, 800]}
              sizes="(min-width: 1024px) 540px, (min-width: 640px) 50vw, 100vw"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
          )
        ) : (
          <div class="flex h-full w-full items-end p-6">
            <h3 class="text-[var(--text-h2)] font-semibold tracking-tight text-[var(--color-ink)]">
              {title}
            </h3>
          </div>
        )
      }
    </div>
    <h3 class="mt-4 text-[var(--text-h3)] font-medium text-[var(--color-ink)]">{title}</h3>
    <p class="mt-2 max-w-prose text-[var(--color-ink-soft)]">{oneline}</p>
    <span class="link-grow mt-3 inline-block text-[var(--text-meta)] text-[var(--color-accent)]">
      Read case study &rarr;
    </span>
  </a>
</article>
